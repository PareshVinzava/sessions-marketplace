# ── Django ───────────────────────────────────────────────────────────────────
# Generate a real key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-change-this-in-production-generate-with-python-secrets
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.docker

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=sessions_marketplace
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
DATABASE_URL=postgresql://postgres:postgres@db:5432/sessions_marketplace

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Google OAuth ──────────────────────────────────────────────────────────────
# REQUIRED for authentication to work.
# Setup: https://console.cloud.google.com
#   1. Create project → APIs & Services → Credentials
#   2. Create OAuth 2.0 Client ID (Web application)
#   3. Authorized redirect URI: http://localhost/api/allauth/google/login/callback/
#   4. Copy Client ID and Secret below
# Leave empty to get a 503 oauth_unconfigured response (not a crash)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FRONTEND_URL=http://localhost

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── Stripe (OPTIONAL) ────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/test/apikeys
# For local webhook testing: stripe listen --forward-to localhost/api/stripe/webhook/
# Leave empty to get a 503 payment_unconfigured response (not a crash)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── MinIO / S3 Storage (OPTIONAL) ────────────────────────────────────────────
# MinIO console available at http://localhost:9001 after docker compose up
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_STORAGE_BUCKET_NAME=sessions-marketplace
# Internal Docker URL (backend → minio container)
AWS_S3_ENDPOINT_URL=http://minio:9000
# Public URL (browser → localhost:9000 for signed file URLs)
AWS_S3_CUSTOM_DOMAIN=localhost:9000/sessions-marketplace
AWS_S3_ADDRESSING_STYLE=path
# MinIO ignores region but boto3 requires it
AWS_S3_REGION_NAME=us-east-1

# ── Frontend (Vite build-time env — VITE_ prefix required) ───────────────────
VITE_API_BASE_URL=/api
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder

# ── Observability (OPTIONAL) ──────────────────────────────────────────────────
# Leave empty to disable Sentry
SENTRY_DSN=
